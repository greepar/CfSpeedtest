<Project Sdk="Microsoft.NET.Sdk.Web">

  <ItemGroup>
    <ProjectReference Include="..\CfSpeedtest.Shared\CfSpeedtest.Shared.csproj" />
  </ItemGroup>

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PublishSingleFile>true</PublishSingleFile>
    <SelfContained>false</SelfContained>
    <Version>1.8.5</Version>
    <AssemblyVersion>1.8.5.0</AssemblyVersion>
    <FileVersion>1.8.5.0</FileVersion>
    <StaticWebAssetsEnabled>false</StaticWebAssetsEnabled>
    <IsTransformWebConfigDisabled>true</IsTransformWebConfigDisabled>
  </PropertyGroup>

  <!-- WebUI 资源编译进程序集。发布单文件时不依赖 wwwroot 或 staticwebassets 清单。 -->
  <ItemGroup>
    <Content Remove="wwwroot\**" />
    <None Remove="wwwroot\**" />
    <Content Update="appsettings.Development.json" CopyToPublishDirectory="Never" />
    <Content Update="web.config" CopyToPublishDirectory="Never" />
    <EmbeddedResource Include="wwwroot\**\*" LogicalName="wwwroot/%(RecursiveDir)%(Filename)%(Extension)" />
  </ItemGroup>

  <!-- 构建 Server 前自动运行前端构建（npm/node 不可用时跳过，不阻断编译） -->
  <Target Name="BuildWebUi" BeforeTargets="CoreCompile" Condition="'$(DesignTimeBuild)' != 'true'">
    <Exec Command="npm run build" WorkingDirectory="..\CfSpeedtest.Web" ContinueOnError="true" IgnoreExitCode="true" />
  </Target>

</Project>
